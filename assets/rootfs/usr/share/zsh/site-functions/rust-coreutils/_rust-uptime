#compdef uptime

autoload -U is-at-least

_uptime() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-s[system up since]' \
'--since[system up since]' \
'-p[show uptime in pretty format]' \
'--pretty[show uptime in pretty format]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::path -- file to search boot time from:_files' \
&& ret=0
}

(( $+functions[_uptime_commands] )) ||
_uptime_commands() {
    local commands; commands=()
    _describe -t commands 'uptime commands' commands "$@"
}

if [ "$funcstack[1]" = "_uptime" ]; then
    _uptime "$@"
else
    compdef _uptime uptime
fi
