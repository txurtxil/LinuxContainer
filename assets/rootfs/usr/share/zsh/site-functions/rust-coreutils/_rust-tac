#compdef tac

autoload -U is-at-least

_tac() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-s+[use STRING as the separator instead of newline]:STRING:_default' \
'--separator=[use STRING as the separator instead of newline]:STRING:_default' \
'-b[attach the separator before instead of after]' \
'--before[attach the separator before instead of after]' \
'-r[interpret the sequence as a regular expression]' \
'--regex[interpret the sequence as a regular expression]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::file:_files' \
&& ret=0
}

(( $+functions[_tac_commands] )) ||
_tac_commands() {
    local commands; commands=()
    _describe -t commands 'tac commands' commands "$@"
}

if [ "$funcstack[1]" = "_tac" ]; then
    _tac "$@"
else
    compdef _tac tac
fi
