# Our units without [Install] are either event driven or statically enabled
udev: systemd-service-file-missing-install-key
# Lintian is really bad at associating manpages
udev: spare-manual-page
# Manpages are autogenerated from DocBook, these warnings are useless
udev: groff-message * [usr/share/man/*]
# Needed as a workaround for dpkg bug w.r.t. usrmerge
udev: conflicts-with-version systemd (<< 255~rc1-4~)
# These are generic rules, they do not provide any specific hardware access
udev: appstream-metadata-missing-modalias-provide usr/lib/udev/rules.d/*
